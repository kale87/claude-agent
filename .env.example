# Ollama base URL — default is localhost, change if Ollama runs elsewhere
OLLAMA_HOST=http://localhost:11434

# Model to use — must be pulled first with: ollama pull llama3.1
# Recommended options:
#   llama3.1        — best all-rounder
#   qwen2.5-coder   — best for coding tasks
#   mistral         — fast and lightweight
OLLAMA_MODEL=llama3.1

# GitHub Personal Access Token — needs repo scope
# Get one at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Optional
# PORT=3000
