ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model to use (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Max tokens per response (default: 4096)
# MAX_TOKENS=4096

# Port (default: 3000)
# PORT=3000

# Absolute path to the git repo you want to manage from the UI.
# This folder will be mounted into the container at /workspace.
# Example (Mac/Linux): GIT_WORKDIR=/Users/you/projects/myapp
# Example (Windows):   GIT_WORKDIR=C:/Users/you/projects/myapp
GIT_WORKDIR=./workspace
